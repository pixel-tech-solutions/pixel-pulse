<Window x:Class="PixelPulse.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pixel Pulse - Settings" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Font Settings -->
            <GroupBox Header="Font Settings">
                <StackPanel Margin="10">
                    <StackPanel>
                        <Label Content="Font Size:"/>
                        <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="48" Value="18" ValueChanged="FontSizeSlider_ValueChanged"/>
                        <TextBlock x:Name="FontSizeText" Text="18" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel>
                        <Label Content="Font Family:"/>
                        <ComboBox x:Name="FontFamilyComboBox" SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel>
                        <Label Content="Text Color:"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="ColorTextBox" Width="100" Text="#FFFFFF" TextChanged="ColorTextBox_TextChanged"/>
                            <Button Content="Pick Color" Click="PickColorButton_Click" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Display Settings -->
            <GroupBox Header="Display Settings">
                <StackPanel Margin="10">
                    <StackPanel>
                        <Label Content="Position:"/>
                        <ComboBox x:Name="PositionComboBox" SelectionChanged="PositionComboBox_SelectionChanged">
                            <ComboBoxItem Content="Top Right" IsSelected="True"/>
                            <ComboBoxItem Content="Top Left"/>
                            <ComboBoxItem Content="Bottom Right"/>
                            <ComboBoxItem Content="Bottom Left"/>
                        </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Always on Top" Checked="AlwaysOnTopCheckBox_Checked" Unchecked="AlwaysOnTopCheckBox_Unchecked"/>
                    <CheckBox x:Name="ClickThroughCheckBox" Content="Click-Through Mode" Checked="ClickThroughCheckBox_Checked" Unchecked="ClickThroughCheckBox_Unchecked"/>
                    <CheckBox x:Name="HoverBrightenCheckBox" Content="Hover to Brighten" Checked="HoverBrightenCheckBox_Checked" Unchecked="HoverBrightenCheckBox_Unchecked"/>
                </StackPanel>
            </GroupBox>

            <!-- Quote Settings -->
            <GroupBox Header="Quote Settings">
                <StackPanel Margin="10">
                    <StackPanel>
                        <Label Content="Refresh Interval:"/>
                        <ComboBox x:Name="RefreshIntervalComboBox" SelectionChanged="RefreshIntervalComboBox_SelectionChanged">
                            <ComboBoxItem Content="30 seconds"/>
                            <ComboBoxItem Content="1 minute"/>
                            <ComboBoxItem Content="5 minutes"/>
                            <ComboBoxItem Content="10 minutes"/>
                            <ComboBoxItem Content="30 minutes"/>
                            <ComboBoxItem Content="1 hour"/>
                            <ComboBoxItem Content="1 day"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <Label Content="Fade After:"/>
                        <ComboBox x:Name="FadeAfterComboBox" SelectionChanged="FadeAfterComboBox_SelectionChanged">
                            <ComboBoxItem Content="30 seconds"/>
                            <ComboBoxItem Content="1 minute"/>
                            <ComboBoxItem Content="5 minutes"/>
                            <ComboBoxItem Content="10 minutes"/>
                            <ComboBoxItem Content="30 minutes"/>
                            <ComboBoxItem Content="1 hour"/>
                            <ComboBoxItem Content="1 day"/>
                            <ComboBoxItem Content="Never"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <Label Content="Enabled Categories:"/>
                        <ListBox x:Name="CategoriesListBox" SelectionMode="Multiple" Height="120">
                            <ListBoxItem Content="Motivational" Tag="Motivational"/>
                            <ListBoxItem Content="Bible" Tag="Bible"/>
                            <ListBoxItem Content="Love" Tag="Love"/>
                            <ListBoxItem Content="Tech" Tag="Tech"/>
                            <ListBoxItem Content="Business" Tag="Business"/>
                            <ListBoxItem Content="Success" Tag="Success"/>
                            <ListBoxItem Content="Leadership" Tag="Leadership"/>
                            <ListBoxItem Content="Wisdom" Tag="Wisdom"/>
                            <ListBoxItem Content="Encouragement" Tag="Encouragement"/>
                            <ListBoxItem Content="Life" Tag="Life"/>
                        </ListBox>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Match Settings -->
            <GroupBox Header="Quote Matching">
                <StackPanel Margin="10">
                    <StackPanel>
                        <Label Content="Match Mode:"/>
                        <ComboBox x:Name="MatchModeComboBox" SelectionChanged="MatchModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="None" Tag="None"/>
                            <ComboBoxItem Content="Motivational + Bible" Tag="MotivationalBible"/>
                            <ComboBoxItem Content="Love + Motivational" Tag="LoveMotivational"/>
                            <ComboBoxItem Content="Success + Leadership" Tag="SuccessLeadership"/>
                            <ComboBoxItem Content="Business + Success" Tag="BusinessSuccess"/>
                            <ComboBoxItem Content="Wisdom + Bible" Tag="WisdomBible"/>
                            <ComboBoxItem Content="Encouragement + Bible" Tag="EncouragementBible"/>
                            <ComboBoxItem Content="Custom" Tag="Custom"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel x:Name="CustomMatchPanel" Visibility="Collapsed">
                        <Label Content="Primary Category:"/>
                        <ComboBox x:Name="PrimaryCategoryComboBox" SelectionChanged="PrimaryCategoryComboBox_SelectionChanged"/>
                        <Label Content="Secondary Category:"/>
                        <ComboBox x:Name="SecondaryCategoryComboBox" SelectionChanged="SecondaryCategoryComboBox_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel>
                        <Label Content="Display Format:"/>
                        <ComboBox x:Name="DisplayFormatComboBox" SelectionChanged="DisplayFormatComboBox_SelectionChanged">
                            <ComboBoxItem Content="Stacked" Tag="Stacked"/>
                            <ComboBoxItem Content="Side by Side" Tag="SideBySide"/>
                            <ComboBoxItem Content="Alternating" Tag="Alternating"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Startup Settings -->
            <GroupBox Header="Startup">
                <StackPanel Margin="10">
                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" Checked="StartWithWindowsCheckBox_Checked" Unchecked="StartWithWindowsCheckBox_Unchecked"/>
                </StackPanel>
            </GroupBox>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="About" Width="100" Height="30" Click="AboutButton_Click" Margin="0,0,10,0"/>
                <Button Content="Save" Width="100" Height="30" Click="SaveButton_Click" Margin="0,0,10,0"/>
                <Button Content="Cancel" Width="100" Height="30" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
