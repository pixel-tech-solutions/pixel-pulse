<Window x:Class="PixelPulse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pixel Pulse" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseRightButtonDown="Window_MouseRightButtonDown"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Storyboard x:Key="FadeOutAnimation">
            <DoubleAnimation Storyboard.TargetName="QuoteTextBlock"
                           Storyboard.TargetProperty="Opacity"
                           From="1.0" To="0.3"
                           Duration="0:0:1"/>
        </Storyboard>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetName="QuoteTextBlock"
                           Storyboard.TargetProperty="Opacity"
                           From="0.3" To="1.0"
                           Duration="0:0:0.5"/>
        </Storyboard>
    </Window.Resources>
    
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Settings" Click="SettingsMenuItem_Click"/>
            <MenuItem Header="Refresh Quote" Click="RefreshMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="About" Click="AboutMenuItem_Click"/>
            <Separator/>
            <MenuItem Header="Exit" Click="ExitMenuItem_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="MainBorder" 
            Background="Transparent"
            Padding="15"
            CornerRadius="5">
        <TextBlock x:Name="QuoteTextBlock"
                   TextWrapping="Wrap"
                   TextAlignment="Right"
                   Foreground="White"
                   FontSize="18"
                   FontFamily="Segoe UI"
                   Opacity="1.0"
                   MaxWidth="400"
                   Text="Loading quotes..."/>
    </Border>
</Window>
